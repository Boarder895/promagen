{
  "$schema": "./schemas/wind.schema.json",
  "version": "4.0.1",
  "meta": {
    "domain": "weather",
    "category": "wind",
    "description": "TEMPLATE-READY: Wind descriptor layer only. 0–150 km/h in 5 km/h bins. Deterministic descriptor per bin. Designed for runtime insertion of exact API wind speed into templates. No object references, no behaviour, no mood, no time/lighting.",
    "range": {
      "min": 0,
      "max": 150,
      "unit": "km/h"
    },
    "updated": "2026-02-18",
    "interval": "5 km/h bins",
    "totalRanges": 30,
    "templates": {
      "numeric_exact": "wind at {speed} km/h",
      "combined_exact": "{descriptor} at {speed} km/h",
      "combined_approx": "{descriptor} around {speed} km/h"
    },
    "notes": "Pick range by speed, read descriptor, then format using templates. Use *_exact when you keep the API value; use *_approx if you round/smooth."
  },
